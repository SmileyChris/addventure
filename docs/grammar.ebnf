(* Addventure Script Grammar — EBNF *)
(* Whitespace-sensitive: indentation is 2-space increments. *)
(* INDENT(n) means exactly n×2 leading spaces.              *)


(* ══════════════════════════════════════════════════════════ *)
(*  Top-level structure                                      *)
(* ══════════════════════════════════════════════════════════ *)

game            = index-file , { room-file } ;

index-file      = [ frontmatter ] , [ description ] , { global-section } ;

room-file       = [ frontmatter ] , { room-section | interactions-section } ;


(* ══════════════════════════════════════════════════════════ *)
(*  Frontmatter                                              *)
(* ══════════════════════════════════════════════════════════ *)

frontmatter     = "---" , newline ,
                  { meta-key , ":" , meta-value , newline } ,
                  "---" , newline ;

meta-key        = text ;            (* title | author | start | entry_prefix | chapters | image *)
meta-value      = text ;


(* ══════════════════════════════════════════════════════════ *)
(*  Description                                              *)
(* ══════════════════════════════════════════════════════════ *)

(* Body text between frontmatter and first # header.         *)
(* Each non-empty, non-comment line becomes a paragraph.     *)

description     = { text-line } ;


(* ══════════════════════════════════════════════════════════ *)
(*  Global sections (index.md only)                          *)
(* ══════════════════════════════════════════════════════════ *)

global-section  = verbs-section | items-section ;

verbs-section   = "# Verbs" , newline , { NAME , newline } ;

items-section   = "# Items" , newline , { NAME , newline , [ noun-block(0) ] } ;


(* ══════════════════════════════════════════════════════════ *)
(*  Room sections                                            *)
(* ══════════════════════════════════════════════════════════ *)

room-section    = room-header , newline , room-body ;

room-header     = "# " , room-name ;

room-body       = { room-level-line } ;

room-level-line = room-interaction          (* LOOK: desc  or  VERB + TARGET: *)
                | room-arrow                (* subject -> dest *)
                | noun-declaration          (* NAME at indent 0 *)
                | action-declaration ;      (* > GO NORTH *)

room-interaction = interaction-header ;     (* context entity = current room *)

room-arrow      = arrow ;


(* ══════════════════════════════════════════════════════════ *)
(*  Nouns                                                    *)
(* ══════════════════════════════════════════════════════════ *)

noun-declaration = INDENT(0) , NAME , newline ,
                   noun-block(0) ;

(* noun-block(n): children of a noun declared at indent n.        *)
(* + lines at indent n define interactions on the noun.           *)
(* Deeper lines are nested content (narratives, arrows, children).*)
(* - arrows at indent n are siblings, not children — they end the block. *)

noun-block(n)   = { INDENT(n) , "+" , " " , interaction-content(n)
                  | INDENT(>n) , "-" , " " , arrow-line(>n)
                  | INDENT(>n) , NAME , newline , noun-block(>n)
                  } ;


(* ══════════════════════════════════════════════════════════ *)
(*  Interactions                                             *)
(* ══════════════════════════════════════════════════════════ *)

interaction-header = [ "+" , " " ] , verb-target-spec , ":" , [ inline-narrative ] , newline ,
                     interaction-body ;

verb-target-spec = NAME , { "+" , target-group } ;

target-group    = noun-ref , { "|" , noun-ref } ;

interaction-body = { narrative-line | arrow-line | action-declaration } ;

narrative-line  = INDENT(>parent) , text ;    (* no marker, no arrow, not ALL_CAPS *)

arrow-line      = "-" , " " , arrow , newline , [ arrow-children ] ;


(* ══════════════════════════════════════════════════════════ *)
(*  Arrows                                                   *)
(* ══════════════════════════════════════════════════════════ *)

arrow           = subject , " -> " , destination
                | " -> " , NAME ;             (* verb reveal: no subject *)

subject         = noun-ref                    (* NOUN, NOUN__STATE *)
                | action-name                 (* GO NORTH — action trash/removal *)
                | "player"
                | "room"
                | "?" ;                       (* cue trigger *)

destination     = "trash"                     (* destroy noun, verb, or action *)
                | "player"                    (* move to inventory *)
                | "room"                      (* reveal in current room, or revert room state *)
                | quoted-room                 (* move to / reveal in named room *)
                | noun-state-ref              (* transform: NOUN__STATE *)
                | NAME                        (* revert: NOUN__STATE -> NOUN *)
                | room-state-ref ;            (* transform: room__STATE *)

quoted-room     = '"' , room-name , '"' ;


(* ══════════════════════════════════════════════════════════ *)
(*  Arrow children                                           *)
(* ══════════════════════════════════════════════════════════ *)

(* What follows an arrow depends on the destination type:    *)

arrow-children  = arrow-children-trash        (* -> trash: skip deeper lines *)
                | arrow-children-player       (* -> player: skip deeper lines *)
                | arrow-children-movement     (* player -> "Room": nothing *)
                | arrow-children-reveal       (* -> room: noun-block for subject *)
                | arrow-children-remote       (* -> "Room": noun-block in target room *)
                | arrow-children-transform    (* -> STATE: noun-block for new state *)
                | arrow-children-room-state   (* -> room__STATE: room-state-block *)
                | arrow-children-cue          (* ? -> "Room": cue block *)
                | arrow-children-verb-reveal  (* -> VERB: nothing *)
                | arrow-children-verb-trash ; (* VERB -> trash: nothing *)

arrow-children-verb-reveal = (* empty — -> VERB has no children *) ;
arrow-children-verb-trash  = (* empty — VERB -> trash has no children *) ;

arrow-children-trash    = { INDENT(>arrow) , any-line } ;   (* consumed and ignored *)
arrow-children-player   = noun-block ;                       (* optional + interactions override/suppress inventory duplicates *)
arrow-children-movement = (* empty — player -> "Room" has no children *) ;

arrow-children-reveal   = noun-block ;        (* defines subject in current room *)
arrow-children-remote   = noun-block ;        (* defines subject in target room *)
arrow-children-transform = noun-block ;       (* defines the new noun state *)

arrow-children-room-state = room-state-block ;

arrow-children-cue      = cue-block ;


(* ══════════════════════════════════════════════════════════ *)
(*  Cue blocks (? -> "Room")                                 *)
(* ══════════════════════════════════════════════════════════ *)

(* A cue defines a deferred cross-room effect. The indented  *)
(* block contains a narrative and arrows that execute when    *)
(* the player enters the target room and the cue resolves.   *)
(*                                                            *)
(* Cue destination determines which room states it fires in:  *)
(*   ? -> "Room"           any state (base + all variants)    *)
(*   ? -> "Room__STATE"    only that specific state           *)
(*   ? -> "Room__"         only the base state (no variant)   *)

cue-block       = { INDENT(>arrow) , ( narrative-line | cue-arrow-line ) } ;

cue-arrow-line  = "-" , " " , cue-arrow , newline ;

cue-arrow       = noun-ref , " -> " , destination ;   (* arrows within the target room *)


(* ══════════════════════════════════════════════════════════ *)
(*  Room state blocks                                        *)
(* ══════════════════════════════════════════════════════════ *)

(* Children of room -> room__STATE arrows.                   *)
(* Can contain interactions, nouns, and arrows.              *)

room-state-block = { INDENT(>=child) , ( room-state-interaction
                                        | room-state-noun
                                        | room-state-arrow ) } ;

room-state-interaction = "+" , " " , interaction-content ;

room-state-noun = [ "+" , " " ] , NAME , newline , noun-block ;

room-state-arrow = "-" , " " , arrow-line ;


(* ══════════════════════════════════════════════════════════ *)
(*  Actions                                                  *)
(* ══════════════════════════════════════════════════════════ *)

(* Actions are direct ledger lookups — no verb+noun addition.  *)
(* ">" declares an action. At room level = pre-printed.        *)
(* Nested inside an interaction = discoverable.                *)

action-declaration = ">" , " " , action-name , newline ,
                     action-body ;

action-name     = ? any non-empty text (spaces allowed) ? ;   (* e.g. GO NORTH, PULL LEVER *)

action-body     = { INDENT(>parent) , ( narrative-line | arrow-line ) } ;


(* ══════════════════════════════════════════════════════════ *)
(*  Freeform interactions (# Interactions section)           *)
(* ══════════════════════════════════════════════════════════ *)

interactions-section = "# Interactions" , newline ,
                       { freeform-interaction } ;

freeform-interaction = freeform-header , newline ,
                       { INDENT(1+) , ( narrative-line | arrow-line ) } ;

freeform-header = NAME , "+" , target-group , { "+" , target-group } , ":" ;


(* ══════════════════════════════════════════════════════════ *)
(*  Noun references                                          *)
(* ══════════════════════════════════════════════════════════ *)

noun-ref        = NAME                        (* e.g. TERMINAL, CRATE *)
                | noun-state-ref              (* e.g. TERMINAL__UNLOCKED *)
                | "*" ;                       (* wildcard: all nouns in room *)

noun-state-ref  = NAME , "__" , STATE-NAME ;

room-state-ref  = "room__" , STATE-NAME ;     (* current room state transform *)


(* ══════════════════════════════════════════════════════════ *)
(*  Terminals                                                *)
(* ══════════════════════════════════════════════════════════ *)

NAME            = UPPER , { UPPER | DIGIT | "_" } ;      (* e.g. TERMINAL, WALL_PANEL, LOOK *)
STATE-NAME      = UPPER , { UPPER | DIGIT | "_" } ;      (* e.g. UNLOCKED, OPEN *)
room-name       = ? any text not containing newline ? ;   (* e.g. Control Room *)

UPPER           = "A" | "B" | ... | "Z" ;
DIGIT           = "0" | "1" | ... | "9" ;

comment         = "//" , ? any text ? , newline ;
newline         = "\n" ;
text            = ? any non-empty text ? ;
text-line       = text , newline ;

(* INDENT(n) = exactly n * 2 space characters at line start *)
(* INDENT(>n) = more than n * 2 space characters            *)
(* INDENT(>=n) = at least n * 2 space characters            *)
(* Blank lines and comment lines are skipped everywhere.    *)
