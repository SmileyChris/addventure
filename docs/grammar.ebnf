(* Addventure Concrete Syntax Specification *)

(* This file documents the concrete source syntax accepted by the parser.
   It is intentionally not a parser-consumable grammar. Structural syntax
   and validation rules are separated so the language definition stays
   precise without smuggling semantic checks into pseudo-EBNF. *)


(* ══════════════════════════════════════════════════════════ *)
(*  1. Lexical Conventions                                   *)
(* ══════════════════════════════════════════════════════════ *)

newline         = "\n" ;
space           = " " ;

comment-line    = indent , "//" , { any-char-except-newline } , newline ;
blank-line      = indent , newline ;

indent          = { space } ;
indent(n)       = ? exactly n space characters ? ;

(* Indentation uses spaces only. Tabs are not allowed in leading whitespace.
   A child line belongs to a block when it is indented deeper than that
   block's header line. Indentation width is otherwise unconstrained. *)
(* `//` may also appear as a trailing comment on structural lines. Trailing
   comments are not stripped from narrative text lines. *)

NAME            = UPPER , { UPPER | DIGIT } , { "_" , UPPER | DIGIT , { UPPER | DIGIT } } ;
STATE-NAME      = NAME ;
STATED-NAME     = NAME , [ "__" , STATE-NAME ] ;

(* Identifier classes:
   NAME         — plain identifier (verbs, items, base room objects, actions).
                  Single underscores separate words; double underscore is not
                  allowed. Starts with a letter.
   STATE-NAME   — same lexical form as NAME; used after `__` in stated forms.
   STATED-NAME  — NAME optionally suffixed with `__STATE-NAME`. Used for verb
                  names in interactions and room object declarations, where a
                  state qualifier is syntactically valid.
   object-ref   — a room object target: plain NAME, stated OBJ__STATE, or wildcard `*`.
   room-name    — free-form text (room headers and quoted targets). Not an
                  identifier; no lexical restrictions beyond non-empty.
   action-name  — plain NAME; actions do not have state variants. *)

object-state-ref  = NAME , "__" , STATE-NAME ;
room-state-ref    = "room__" , STATE-NAME ;

object-ref        = "*" | object-state-ref | NAME ;

quoted-room     = '"' , room-name , '"' ;
room-name       = ? any non-empty text not containing newline or '"' ? ;

text            = ? any non-empty text not containing newline ? ;
action-name     = NAME ;

UPPER           = "A" | "B" | ... | "Z" ;
DIGIT           = "0" | "1" | ... | "9" ;


(* ══════════════════════════════════════════════════════════ *)
(*  2. Top-Level File Shapes                                *)
(* ══════════════════════════════════════════════════════════ *)

game            = index-file , { room-file } ;

index-file      = [ frontmatter ] ,
                  { blank-line | comment-line } ,
                  [ description ] ,
                  { global-section | blank-line | comment-line } ;

room-file       = [ frontmatter ] ,
                  { blank-line | comment-line } ,
                  room-section ,
                  { room-section | blank-line | comment-line } ;

(* `## Interactions` is part of the current room section, not a standalone
   top-level file section. *)


(* ══════════════════════════════════════════════════════════ *)
(*  3. Frontmatter and Description                          *)
(* ══════════════════════════════════════════════════════════ *)

frontmatter     = "---" , newline ,
                  { frontmatter-line | blank-line | comment-line } ,
                  "---" , newline ;

frontmatter-line = text , ":" , [ text ] , newline ;

description     = description-line , { blank-line | comment-line | description-line } ;
description-line = indent0 , text , newline ;

indent0         = "" ;


(* ══════════════════════════════════════════════════════════ *)
(*  4. Global Sections                                      *)
(* ══════════════════════════════════════════════════════════ *)

global-section  = verbs-section | inventory-section ;

verbs-section   = "# Verbs" , newline ,
                  { blank-line | comment-line | verb-line } ;

verb-line       = indent0 , NAME , newline ;

inventory-section = "# Inventory" , newline ,
                    { blank-line | comment-line | item-declaration } ;

item-declaration = indent0 , NAME , newline ,
                   [ entity-block(0) ] ;


(* ══════════════════════════════════════════════════════════ *)
(*  5. Room Sections                                        *)
(* ══════════════════════════════════════════════════════════ *)

room-section    = room-header , newline ,
                  room-body ,
                  [ interactions-section ] ;

room-header     = "# " , room-name ;

room-body       = { blank-line | comment-line | room-body-line } ;

room-body-line  = room-interaction
                | room-arrow
                | object-declaration
                | action-declaration ;

room-interaction = indent0 , interaction-header ;
room-arrow      = indent0 , arrow , newline , [ arrow-children(0, arrow) ] ;
object-declaration = indent0 , STATED-NAME , newline , [ entity-block(0) ] ;


(* ══════════════════════════════════════════════════════════ *)
(*  6. Entity Blocks                                        *)
(* ══════════════════════════════════════════════════════════ *)

(* An entity block is the indented content under a room object or inventory object
   declaration, or under a reveal / transform arrow that introduces a room object. *)

entity-block(n) = entity-line(n+1) , { blank-line | comment-line | entity-line(n+1) } ;

entity-line(m)  = interaction-line(m)
                | arrow-line(m)
                | nested-object(m)
                | action-line(m) ;

interaction-line(m) = indent(m) , "+ " , interaction-header ;
arrow-line(m)       = indent(m) , "- " , arrow , newline , [ arrow-children(m, arrow) ] ;
nested-object(m)    = indent(m) , STATED-NAME , newline , [ entity-block(m) ] ;
action-line(m)      = indent(m) , "> " , action-name , newline , action-body(m) ;


(* ══════════════════════════════════════════════════════════ *)
(*  7. Interactions                                         *)
(* ══════════════════════════════════════════════════════════ *)

interaction-header = verb-target-spec , ":" , [ inline-narrative ] , newline ,
                     [ interaction-body(same-line-indent) ] ;

verb-target-spec   = STATED-NAME , { "+" , target-group } ;
target-group       = object-ref , { "|" , object-ref } ;
inline-narrative   = text ;

interaction-body(n) = interaction-body-line(n+1) ,
                      { blank-line | comment-line | interaction-body-line(n+1) } ;

interaction-body-line(m) = narrative-line(m)
                         | arrow-line(m)
                         | action-line(m) ;

narrative-line(m) = indent(m) , text , newline ;
(* Consecutive narrative-lines (no blank-line between) are joined as one paragraph.
   A blank-line between narrative-lines starts a new paragraph. *)

(* Fragment blocks — long-form hidden content within an interaction *)
fragment-block   = fragment-open , { fragment-line } , fragment-close ;
fragment-open    = indent , "::: fragment" , newline ;
fragment-close   = indent , ":::" , newline ;
fragment-line    = indent , text-line ;

(* interaction-body optionally ends with a fragment-block:
   interaction-body(n) = ... , [ fragment-block ] *)


(* ══════════════════════════════════════════════════════════ *)
(*  8. Arrows                                               *)
(* ══════════════════════════════════════════════════════════ *)

arrow            = subject , " -> " , destination
                 | " -> " , NAME ;

subject          = object-ref
                 | action-name
                 | "player"
                 | "room"
                 | "?" ;

destination      = "trash"
                 | "player"
                 | "room"
                 | "signal"
                 | quoted-room
                 | object-state-ref
                 | NAME
                 | room-state-ref ;


(* ══════════════════════════════════════════════════════════ *)
(*  9. Arrow Child Blocks                                   *)
(* ══════════════════════════════════════════════════════════ *)

(* The allowed child block depends on the arrow form. *)

arrow-children(n, subject -> "player")       = entity-block(n) ;
arrow-children(n, subject -> "room")         = entity-block(n) ;
arrow-children(n, subject -> quoted-room)    = entity-block(n) ;
arrow-children(n, subject -> object-state-ref) = entity-block(n) ;
arrow-children(n, "room" -> room-state-ref)  = room-state-block(n) ;
arrow-children(n, "?" -> quoted-room)        = cue-block(n) ;

(* These arrow forms have no children: *)
(*   subject -> trash *)
(*   player -> "Room" *)
(*   -> VERB *)
(*   VERB -> trash *)
(*   VERB__STATE -> VERB *)


(* ══════════════════════════════════════════════════════════ *)
(*  10. Cue Blocks                                          *)
(* ══════════════════════════════════════════════════════════ *)

cue-block(n)     = cue-line(n+1) , { blank-line | comment-line | cue-line(n+1) } ;

cue-line(m)      = narrative-line(m)
                 | cue-arrow-line(m) ;

cue-arrow-line(m) = indent(m) , "- " , cue-arrow , newline ;
cue-arrow        = object-ref , " -> " , destination ;


(* ══════════════════════════════════════════════════════════ *)
(*  11. Room-State Blocks                                   *)
(* ══════════════════════════════════════════════════════════ *)

room-state-block(n) = room-state-line(n+1) ,
                      { blank-line | comment-line | room-state-line(n+1) } ;

room-state-line(m)  = room-state-interaction(m)
                    | room-state-object(m)
                    | room-state-arrow(m) ;

room-state-interaction(m) = indent(m) , "+ " , interaction-header ;
room-state-object(m)      = indent(m) , [ "+ " ] , STATED-NAME , newline , [ entity-block(m) ] ;
room-state-arrow(m)       = indent(m) , "- " , arrow , newline , [ arrow-children(m, arrow) ] ;


(* ══════════════════════════════════════════════════════════ *)
(*  12. Actions                                              *)
(* ══════════════════════════════════════════════════════════ *)

action-declaration = indent0 , "> " , action-name , newline , action-body(0) ;

action-body(n)     = action-body-line(n+1) ,
                     { blank-line | comment-line | action-body-line(n+1) } ;

action-body-line(m) = narrative-line(m)
                    | arrow-line(m) ;

(* Actions may appear:
   - at room level: pre-printed action on the room sheet
   - inside an interaction body: discoverable action *)


(* ══════════════════════════════════════════════════════════ *)
(*  13. Freeform Interactions                               *)
(* ══════════════════════════════════════════════════════════ *)

interactions-section = "## Interactions" , newline ,
                       { blank-line | comment-line | freeform-interaction } ;

freeform-interaction = indent0 , freeform-header , newline ,
                       freeform-body(0) ;

freeform-header      = STATED-NAME , "+" , target-group , { "+" , target-group } , ":" ;

freeform-body(n)     = freeform-body-line(n+1) ,
                       { blank-line | comment-line | freeform-body-line(n+1) } ;

freeform-body-line(m) = narrative-line(m)
                      | arrow-line(m)
                      | action-line(m) ;


(* ══════════════════════════════════════════════════════════ *)
(*  13b. Signals                                            *)
(* ══════════════════════════════════════════════════════════ *)

(* ── Signals ────────────────────────────────────────────────────────────── *)

(* Signals are derived from emission arrows and signal check blocks.
   No declaration section is needed. *)

signal_names        = NAME { " + " NAME } ;
signal_check        = signal_names "?" newline indented_block ;
otherwise_check     = "otherwise?" newline indented_block ;
signal_check_group  = { signal_check } [ otherwise_check ] ;

(* Signal emission: NAME -> signal (subject is the signal name, destination is `signal`)
   Signal check groups can appear in:
   - The description block (between frontmatter and `# Verbs`) — fires at chapter start
   - Interaction bodies (after narrative and arrows) — fires during play
   First matching branch wins — the player reads the first check that matches. *)


(* ══════════════════════════════════════════════════════════ *)
(*  14. Validation Rules                                    *)
(* ══════════════════════════════════════════════════════════ *)

(* These are part of the language definition, but they are semantic
   validation rules rather than concrete syntax.

   1. Tabs are not allowed in indentation.
   2. `# Verbs` lines must be unindented verb declarations only.
   3. `# Inventory` lines must be unindented item declarations only.
   4. `## Interactions` may contain freeform interactions only.
   5. Every child line in a block must be indented deeper than its header.
   6. `-> trash`, `player -> "Room"`, `-> VERB`, and verb-only arrows may not
      have child blocks.
   7. `?` arrows must target a quoted room name.
   8. Unknown verbs, unknown targets, and invalid cue target rooms are rejected
      during compilation.
   9. `-> player` requires a `TAKE` verb to exist.
   10. Duplicate authored interactions are invalid.
   11. Empty interactions are syntactically valid but resolve as suppression
       markers rather than ledger entries.
   12. Room names are free text. `NAME`-shaped identifiers are used for verbs,
       room objects, inventory objects, states, and actions.
   13. In productions like `interaction-body(same-line-indent)`, the parameter
       refers to the indentation depth of the line that introduced the block.
   14. `name_style` is optional frontmatter metadata controlling how identifiers
       are rendered for players. Supported values are `upper_words` (default)
       and `title`. This affects rendered verbs, room objects, inventory objects,
       states, and actions, but not free-text room names or narrative.
   15. `*` is only valid as the entire target list of an interaction, for
       example `LOOK + *:`. It may not appear inside multi-target or
       alternation forms such as `USE + * + KEY:` or `USE + BOX|*:`.
   16. Inside an indented block, any deeper non-comment line must be valid for
       that block type. Unexpected lines are parse errors; they are not ignored
       or skipped.
   17. Room bodies are strict: only room-body-line productions, blank lines,
       and comments are allowed. Unrecognized lines are parse errors.
   18. The global file is strict outside sections: only section headers, blank
       lines, and comments are allowed between (and after) global sections.
   19. Unknown frontmatter keys are syntactically valid but produce build
       warnings. Known keys: title, author, start, ledger_prefix, image,
       image_height, name_style. *)
